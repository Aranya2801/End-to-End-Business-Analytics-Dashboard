# ════════════════════════════════════════════════════════════
# NexAnalytics — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ════════════════════════════════════════════════════════════

# ─── Application ─────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
APP_NAME=NexAnalytics

# ─── Backend Server ──────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ─── Database (PostgreSQL) ───────────────────────────────────
POSTGRES_PASSWORD=analytics123
DATABASE_URL=postgresql://analytics:analytics123@localhost:5432/analytics_db

# ─── DuckDB (Analytical Engine) ──────────────────────────────
DUCKDB_PATH=./data/analytics.duckdb
DUCKDB_MEMORY_LIMIT=4GB
DUCKDB_THREADS=4

# ─── Redis (Caching) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT Authentication ──────────────────────────────────────
JWT_SECRET_KEY=jwt-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── AI / LLM Configuration ──────────────────────────────────
# Choose one: openai | anthropic | ollama
AI_PROVIDER=openai

# OpenAI (GPT-4o recommended)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Anthropic Claude (alternative)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Ollama (local LLM - free, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# AI Settings
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.1

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ─── Email (Optional) ────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
FROM_EMAIL=analytics@yourcompany.com

# ─── Slack Notifications (Optional) ─────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#analytics-alerts

# ─── Monitoring (Optional) ───────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
LOG_LEVEL=INFO

# ─── Deployment ──────────────────────────────────────────────
DOMAIN=yourplatform.io
GRAFANA_PASSWORD=admin123

# Railway
RAILWAY_TOKEN=your-railway-token

# Vercel
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_PROJECT_ID=your-vercel-project-id

# ─── Feature Flags ───────────────────────────────────────────
ENABLE_AI_FEATURES=true
ENABLE_ML_FEATURES=true
ENABLE_REAL_TIME_METRICS=true
ENABLE_PDF_EXPORT=true
ENABLE_SLACK_NOTIFICATIONS=false
ENABLE_EMAIL_REPORTS=false
